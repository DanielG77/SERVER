# Database Configuration
POSTGRES_DB=tournaments_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend Configuration
# Port inside container is 8080. Mapped to 8081 on host usually.
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/tournaments_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_FLYWAY_ENABLED=true

# Frontend Configuration
# Nginx listen port inside container is 80. Mapped to 8080 on host usually.
